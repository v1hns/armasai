# ── Vercel env vars (Project → Settings → Environment Variables) ─────────────────
# Server-side secrets — DO NOT prefix with VITE_ (that inlines them into the
# public client bundle).

# Gemini Developer API key — used by api/analyze-frames.js for perception.
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional model override (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ── Local dev only (Express server.js / Design Studio) ──────────────────────────
ANTHROPIC_API_KEY=your_key_here
PORT=3001

# Do NOT set on Vercel — these force the Vertex ADC path, which has no
# credentials in a serverless environment:
#   GOOGLE_GENAI_USE_VERTEXAI, GOOGLE_CLOUD_PROJECT, GOOGLE_CLOUD_LOCATION
